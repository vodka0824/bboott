# --- 基本設定 ---
PORT=8080
BASE_URL=https://your-domain.com

# --- LINE 設定 ---
LINE_TOKEN=your_line_channel_access_token
LINE_CHANNEL_SECRET=your_line_channel_secret

# --- 管理員設定 ---
ADMIN_USER_ID=your_admin_user_id

# --- 資料庫設定 (MongoDB) ---
MONGODB_URI=mongodb://127.0.0.1:27017/linebot
MONGODB_DB_NAME=linebot

# --- AI 與第三方 API 設定 ---
GEMINI_KEY=your_gemini_api_key
GROQ_KEY=your_groq_api_key
CWA_API_KEY=your_cwa_api_key_here
MOENV_API_KEY=optional_moenv_key
GOOGLE_DRIVE_API_KEY=your_google_drive_api_key
GOOGLE_PLACES_API_KEY=your_google_places_api_key

# --- 系統進階設定 (Optional) ---
ECONOMY_COLLECTION=economy_users

# --- GCP 設定 (Optional if running locally) ---
GOOGLE_CLOUD_PROJECT=your_project_id
